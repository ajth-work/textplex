{
  "name": "textplex",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "devDependencies": {
    "eslint": "^9.39.5",
    "postcss": "^8.5.21",
    "sharp": "^0.35.3",
    "supabase": "^2.109.1",
    "typescript": "5.4.5"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "$sharp"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  },
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:web:demo": "node ./scripts/build_web_demo.mjs",
    "lint:web": "npm --workspace apps/web run lint",
    "test:web": "node ./scripts/check_web_reachability.mjs",
    "test:web:reader": "node --test tests/web/reader-route.test.js",
    "test:web:phase3": "node --test tests/web/analysis-book-detail.test.js",
    "test:web:phase4": "node --test tests/web/phase4-deployment.test.js",
    "test:web:phase5": "node --test tests/web/phase5-auth-contract.test.js",
    "test:site": "node ./scripts/run-site-tests.mjs",
    "test:maintenance": "node --test tests/maintenance/update-repair-cycle.test.js",
    "backup:data": "node ./scripts/data-backup.mjs --mode backup --books ./data/books --user ./data/user --output ./artifacts/textplex-backup.tar.gz",
    "restore:data": "node ./scripts/data-backup.mjs --mode restore",
    "maintenance:check": "node ./scripts/update-repair-cycle.mjs --mode report",
    "maintenance:repair": "node ./scripts/update-repair-cycle.mjs --mode repair",
    "maintenance:update": "node ./scripts/update-repair-cycle.mjs --mode update",
    "check:web": "npm run test:web",
    "stack:up": "docker compose up --build",
    "stack:down": "docker compose down"
  }
}
